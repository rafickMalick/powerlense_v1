# ── Claude AI (sessions locales, non partageable) ─────────────────────────
.claude/
plans/
claude.md
AGENTS.md

# ── Logs runtime ──────────────────────────────────────────────────────────
*.log
backend.log
metro.log

# ── Captures d'écran & binaires temporaires (racine) ──────────────────────
*.png
*.jpg
*.jpeg
*.gif

# EXCEPTION : les assets de l'application (icônes, logo, splash) sont
# indispensables au build — sans eux `expo export` échoue. Les règles d'images
# ci-dessus ne visent que les captures d'écran de développement à la racine.
!powerlens-mobile/assets/**
!landing/assets/**
*.bmp
*.docx
*.xlsx
*.pptx
*.pdf

# ── Variables d'environnement (secrets) ───────────────────────────────────
.env
.env.*
!.env.example

# ── Éditeurs ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-workspace
*.suo
*.user

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ── Node (racine, si scripts communs) ─────────────────────────────────────
node_modules/

# ── Divers runtime ────────────────────────────────────────────────────────
*.pid
*.pid.lock
*.seed

# Toolchain local installé pour compiler le firmware (arduino-cli) — ne pas versionner
tools/

# Sauvegardes locales
*.bak

# Archives de handoff design (sources, non nécessaires au build)
*.zip

# Sortie du build web unifié
dist/
